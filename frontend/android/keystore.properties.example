# Copy to keystore.properties (gitignored) and fill in for release signing.
# Generate a keystore:
#   keytool -genkeypair -v -keystore petwalk-release.keystore -alias petwalk \
#     -keyalg RSA -keysize 2048 -validity 10000
storeFile=petwalk-release.keystore
storePassword=CHANGE_ME
keyAlias=petwalk
keyPassword=CHANGE_ME
